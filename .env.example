# Core
NODE_ENV=production
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DB_NAME

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
NEXT_PUBLIC_SUPABASE_AUTH_REDIRECT_URL=https://your-app.vercel.app/auth/callback

# App URL
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Maps
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY

# OSINT / Search / Phone intelligence
SERPAPI_API_KEY=YOUR_SERPAPI_API_KEY
TRUECALLER_API_KEY=YOUR_TRUECALLER_API_KEY
TRUECALLER_LOOKUP_URL=https://api.truecaller.com/v1/search
TRUECALLER_API_BASE=https://api.truecaller.com

# Cloudinary
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=YOUR_CLOUDINARY_CLOUD_NAME
CLOUDINARY_API_KEY=YOUR_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=YOUR_CLOUDINARY_API_SECRET

# Upstash Redis (cache + rate limit)
UPSTASH_REDIS_REST_URL=https://YOUR-UPSTASH-ID.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_UPSTASH_REDIS_REST_TOKEN

# Optional Redis queue (BullMQ worker)
REDIS_URL=redis://127.0.0.1:6379

# Hidden admin bootstrap (server-side only)
HIDDEN_ADMIN_EMAILS=founder@example.com,admin@example.com
